<!-- ============================================================ -->
<!-- Archivo: App.config                                                   -->
<!-- Propósito: Archivo de configuración de la aplicación .NET Framework. -->
<!-- Contiene la cadena de conexión a la base de datos y la configuración -->
<!-- de la versión del runtime requerida.                                 -->
<!-- ============================================================ -->

<configuration>

	<!-- =============================== -->
	<!-- CADENAS DE CONEXIÓN A LA BD      -->
	<!-- =============================== -->
	<connectionStrings>
		<!-- Define la conexión a SQL Server con autenticación de Windows -->
		<add name="EventPlannerDB"
			 connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=EventPlannerDB;Integrated Security=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>

	<!-- =============================== -->
	<!-- CONFIGURACIÓN DE INICIO          -->
	<!-- =============================== -->
	<startup>
		<!-- Especifica la versión de .NET Framework requerida (v4.7.2) -->
		<supportedRuntime version="v4.0"
			sku=".NETFramework,Version=v4.7.2" />
	</startup>

</configuration>