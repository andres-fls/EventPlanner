<!-- ============================================================ -->
<!-- Archivo: packages.config                                      -->
<!-- Propósito: Administra los paquetes NuGet utilizados en el     -->
<!-- proyecto EventPlanner. Cada package define una dependencia   -->
<!-- externa con su versión específica y el framework objetivo.   -->
<!-- ============================================================ -->

<packages>
	<!-- BouncyCastle.Cryptography: Librería criptográfica utilizada -->
	<!-- para encriptación/desencriptación de datos (contraseñas, etc.) -->
	<package id="BouncyCastle.Cryptography" version="2.6.2" targetFramework="net472" />

	<!-- iTextSharp: Librería para generación de documentos PDF.      -->
	<!-- Se utiliza en la exportación de reportes desde el formulario -->
	<!-- ReportesForm.cs                                                -->
	<package id="iTextSharp" version="5.5.13.5" targetFramework="net472" />
</packages>